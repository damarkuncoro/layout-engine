{
  "name": "layout-engine-react",
  "version": "0.1.0",
  "description": "React adapter for layout-engine (headless → React components)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "layout",
    "react",
    "headless",
    "responsive",
    "primitives"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "layout-engine": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "layout-engine": "file:../layout-engine"
  }
}
