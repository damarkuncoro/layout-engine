{
  "name": "@damarkuncoro/layout-engine-react",
  "version": "0.1.1",
  "description": "React adapter for layout-engine (headless → React components)",
  "license": "MIT",
  "type": "module",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "sideEffects": false,
  "files": [
    "lib"
  ],
  "keywords": [
    "layout",
    "react",
    "headless",
    "responsive",
    "primitives"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "postbuild:cjs": "node scripts/ensure-cjs.js",
    "build": "npm run build:esm && npm run build:cjs && npm run postbuild:cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@damarkuncoro/layout-engine": "workspace:*",
    "@damarkuncoro/navbar-engine": "workspace:*",
    "@damarkuncoro/sidebar-engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@damarkuncoro/layout-engine": "workspace:*",
    "@damarkuncoro/navbar-engine": "workspace:*",
    "@damarkuncoro/sidebar-engine": "workspace:*",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
